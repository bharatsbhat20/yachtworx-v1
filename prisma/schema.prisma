generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  role          String    @default("OWNER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  boats             Boat[]
  documents         Document[]
  serviceProvider   ServiceProvider?
  sentMessages      Message[]                  @relation("SentMessages")
  conversations     ConversationParticipant[]
  serviceRequests   ServiceRequest[]           @relation("OwnerRequests")
  maintenanceAlerts MaintenanceAlert[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Boat {
  id                 String   @id @default(cuid())
  ownerId            String
  name               String
  make               String
  model              String
  year               Int
  loa                Float?
  beam               Float?
  draft              Float?
  hullType           String?
  engineType         String?
  registrationNumber String?
  homePort           String?
  purchaseYear       Int?
  purchasePrice      Float?
  estimatedValue     Float?
  imageUrl           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner             User               @relation(fields: [ownerId], references: [id])
  components        BoatComponent[]
  documents         Document[]
  serviceRequests   ServiceRequest[]
  maintenanceAlerts MaintenanceAlert[]
  valueHistory      BoatValueEntry[]
}

model BoatComponent {
  id           String    @id @default(cuid())
  boatId       String
  category     String
  name         String
  manufacturer String?
  model        String?
  serialNumber String?
  installDate  DateTime?
  lastService  DateTime?
  nextService  DateTime?
  status       String    @default("GOOD")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  boat     Boat             @relation(fields: [boatId], references: [id], onDelete: Cascade)
  services ComponentService[]
}

model ComponentService {
  id          String   @id @default(cuid())
  componentId String
  date        DateTime
  description String
  cost        Float?
  providerId  String?
  notes       String?

  component BoatComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
}

model BoatValueEntry {
  id     String   @id @default(cuid())
  boatId String
  date   DateTime
  value  Float
  source String?

  boat Boat @relation(fields: [boatId], references: [id], onDelete: Cascade)
}

model ServiceProvider {
  id           String   @id @default(cuid())
  userId       String   @unique
  businessName String
  description  String?
  location     String?
  latitude     Float?
  longitude    Float?
  phone        String?
  website      String?
  logoUrl      String?
  verified     Boolean  @default(false)
  rating       Float    @default(0)
  reviewCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  certifications  Certification[]
  servicesOffered ServiceOffering[]
  serviceRequests ServiceRequest[]  @relation("ProviderRequests")
}

model Certification {
  id         String    @id @default(cuid())
  providerId String
  name       String
  issuedBy   String?
  issuedAt   DateTime?
  expiresAt  DateTime?
  imageUrl   String?

  provider ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model ServiceOffering {
  id          String  @id @default(cuid())
  providerId  String
  category    String
  name        String
  description String?
  priceFrom   Float?

  provider ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
}

model ServiceRequest {
  id          String    @id @default(cuid())
  ownerId     String
  boatId      String
  providerId  String?
  title       String
  description String
  category    String
  status      String    @default("PENDING")
  urgency     String    @default("NORMAL")
  quotedPrice Float?
  finalPrice  Float?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner         User              @relation("OwnerRequests", fields: [ownerId], references: [id])
  boat          Boat              @relation(fields: [boatId], references: [id])
  provider      ServiceProvider?  @relation("ProviderRequests", fields: [providerId], references: [id])
  documents     Document[]
  statusHistory RequestStatusHistory[]
}

model RequestStatusHistory {
  id        String   @id @default(cuid())
  requestId String
  status    String
  note      String?
  createdAt DateTime @default(now())

  request ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

model Document {
  id        String    @id @default(cuid())
  ownerId   String
  boatId    String?
  requestId String?
  type      String    @default("OTHER")
  name      String
  fileUrl   String
  fileSize  Int?
  mimeType  String?
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  owner   User            @relation(fields: [ownerId], references: [id])
  boat    Boat?           @relation(fields: [boatId], references: [id])
  request ServiceRequest? @relation(fields: [requestId], references: [id])
}

model MaintenanceAlert {
  id          String    @id @default(cuid())
  userId      String
  boatId      String
  title       String
  description String?
  dueDate     DateTime?
  priority    String    @default("MEDIUM")
  dismissed   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
  boat Boat @relation(fields: [boatId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String   @id @default(cuid())
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  unreadCount    Int       @default(0)
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])
}
